# Backend
# Copy this file to .env at the project root before running the backend.
SECRET_KEY=replace-with-a-long-random-secret-before-viva
ACCESS_TOKEN_EXPIRE_MINUTES=1440
PASSWORD_RESET_OTP_EXPIRE_MINUTES=10
PASSWORD_RESET_MAX_ATTEMPTS=5
PASSWORD_RESET_DEMO_MODE=true
DATABASE_URL=sqlite:///./gaba_cabs.db

# Frontend
# Copy this value to frontend/.env.local if needed.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
